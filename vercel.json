{
  "version": 2,
  "rewrites": [
    {
      "source": "/static/(.*)",
      "destination": "/static/$1"
    },
    {
      "source": "/favicon.ico",
      "destination": "/static/favicon.png"
    },
    {
      "source": "/favicon.png",
      "destination": "/static/favicon.png"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}

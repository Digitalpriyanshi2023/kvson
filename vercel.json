{
  "version": 2,
  "routes": [
    { "src": "/api/directory", "dest": "/api/directory.js" },
    { "src": "/api/login", "dest": "/api/login.js" },
    { "src": "/api/enroll", "dest": "/api/enroll.js" },
    { "src": "/api/admin/(.*)", "dest": "/api/admin.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
# KVSON Server Environment Configuration Template
# Copy this file to '.env' and fill in your details.

PORT=3000

# Supabase Credentials (required for database synchronization)
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-string

# JWT Security Setup (required for secure session authentication)
JWT_SECRET=your-extremely-secure-random-secret-string-at-least-32-chars
